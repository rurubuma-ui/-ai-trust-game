{
  "name": "yandex-ai-or-real",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:client": "ws --directory client --port 4173",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "bot": "node bot.js",
    "dev:all": "concurrently \"npm:dev:server\" \"npm:dev:client\" \"npm:bot\"",
    "lint": "eslint \"{client,server}/**/*.js\"",
    "test": "node --test",
    "check-config": "node scripts/check-config.mjs",
    "update-manifest": "node scripts/update-manifest.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "node-fetch": "^3.3.2",
    "node-telegram-bot-api": "^0.67.0",
    "uuid": "^9.0.1",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "eslint": "^9.9.0",
    "local-web-server": "^5.3.0"
  }
}
