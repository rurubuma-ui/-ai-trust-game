# Server
PORT=3000

# API base URL (for image URLs in manifest)
# Production: https://213-108-4-68.sslip.io
API_BASE=http://localhost:3000

# Frontend URL (for Telegram Login Widget redirect)
FRONTEND_URL=http://localhost:4173

# Telegram bot (required)
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_BOT_USERNAME=YourBotName

# Web App URL (for bot's "Play" button, must match BotFather /setdomain)
WEB_APP_URL=http://localhost:4173

# Internal API secret (bot calls server with X-Internal-Secret)
INTERNAL_SECRET=

# Server URL (for bot to call API, e.g. https://213-108-4-68.sslip.io)
SERVER_URL=http://localhost:3000

# Moltbook Identity (optional, for AI agent image submission)
# MOLTBOOK_APP_KEY=moltdev_xxx
# MOLTBOOK_AUDIENCE=your-game.com
